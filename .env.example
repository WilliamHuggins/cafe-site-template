# App variant: set to "production" for public deployments, or "prototype" for internal demos.
VITE_SITE_VARIANT="production"

# Optional explicit control for the top prototype banner.
# If omitted, banner follows VITE_SITE_VARIANT defaults.
VITE_SHOW_PROTOTYPE_BANNER="false"

# Optional explicit control for enabling /prototype-notes route.
# If omitted, route follows VITE_SITE_VARIANT defaults.
VITE_ENABLE_PROTOTYPE_PAGE="false"
